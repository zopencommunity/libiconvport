diff --git a/lib/genflags.c b/lib/genflags.c
index 9f3d15d..2b97f78 100644
--- a/lib/genflags.c
+++ b/lib/genflags.c
@@ -74,6 +74,24 @@ static void emit_encoding (struct wctomb_funcs * ofuncs, const char* c_name)
         printf("HAVE_HANGUL_JAMO");
         first = 0;
       }
+      {
+        /* See whether the encoding is an EBCDIC encoding. */
+        ucs4_t ebcdic_probe[2] = { 0x0085, 0x000A };
+        int ebcdic_res[2] = { 0, 0 };
+        for (i = 0; i < 2; i++) {
+          unsigned char buf[10];
+          memset(&conv.ostate,'\0',sizeof(state_t));
+          if (conv.ofuncs.xxx_wctomb(&conv,buf,ebcdic_probe[i],sizeof(buf)) == 1) {
+            if (i == 0) ebcdic_res[0] = (buf[0] == 0x15);
+            else ebcdic_res[1] = (buf[0] == 0x25);
+          }
+        }
+        if (ebcdic_res[0] && ebcdic_res[1]) {
+          if (!first) printf(" | ");
+          printf("HAVE_EBCDIC");
+          first = 0;
+        }
+      }
       if (first) printf("0");
     }
     printf(")\n");
@@ -99,6 +117,10 @@ int main ()
   printf("   the double-width Hangul letters (Jamo) U+3131 to U+3163. */\n");
   printf("#define HAVE_HANGUL_JAMO %d\n",bitmask);
   printf("\n");
+  bitmask = bitmask << 1;
+  printf("/* Set if the encoding is an EBCDIC encoding for z/OS. */\n");
+  printf("#define HAVE_EBCDIC %d\n",bitmask);
+  printf("\n");
 
